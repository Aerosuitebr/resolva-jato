# =============================================================================
# Desenvolvimento local
# =============================================================================
# Opção A — Supabase (PostgreSQL gerenciado):
# DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
#
# Opção B — Docker de produção/local (stack completa): veja .env.production.example e DOCKER.md
# DATABASE_URL="postgresql://resolvajato:SENHA@localhost:5432/resolvajato?schema=public"

DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# URL pública do app (links de orçamento / retorno Mercado Pago)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- WhatsApp (Evolution) — dev: npm run whatsapp:up ---
# 1) npm run whatsapp:up
# 2) npm run whatsapp:setup
# 3) Escaneie o QR em Minha conta (ou GET /api/whatsapp/status)
WHATSAPP_PROVIDER="evolution"
WHATSAPP_API_ENABLED="true"
EVOLUTION_API_URL="http://localhost:18083"
WHATSAPP_API_URL="http://localhost:18083"
EVOLUTION_API_KEY="resolva-jato-evolution-api-key-2026"
WHATSAPP_API_TOKEN="resolva-jato-evolution-api-key-2026"
WHATSAPP_INSTANCE="resolva-jato"

# E-mail (SMTP — mesmo padrão do Aerosuite / Gmail)
# Preferencial. Se ausente, tenta RESEND_API_KEY.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="contato@aerosuite.com.br"
SMTP_PASSWORD=""
SMTP_FROM="Resolva Jato <noreply@aerosuite.com.br>"
SMTP_SSL="false"
SMTP_START_TLS="REQUIRED"

# Fallback opcional (Resend)
RESEND_API_KEY=""
RESEND_FROM="Resolva Jato <onboarding@resend.dev>"

# Auth (cookie de sessão) — gere com: openssl rand -hex 32
AUTH_SECRET="troque-por-um-segredo-longo-em-producao"

# Cloudflare Turnstile (cadastro) — https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SECRET_KEY=""
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
# Em desenvolvimento, sem as chaves o captcha é ignorado.

# SMS (Twilio) — opcional
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# Mercado Pago Checkout Pro
# Credenciais em: Suas integrações > Resolva Jato > Credenciais de teste / produção
# production = dinheiro real (init_point) | sandbox = credenciais de teste
MERCADOPAGO_MODE="production"
NEXT_PUBLIC_MERCADOPAGO_MODE="production"
MERCADOPAGO_ACCESS_TOKEN=""
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=""
# Opcionais (OAuth / algumas integrações)
MERCADOPAGO_CLIENT_ID=""
MERCADOPAGO_CLIENT_SECRET=""
# Opcional (quando configurar assinatura secreta do webhook no painel)
MERCADOPAGO_WEBHOOK_SECRET=""

# Web Push (opcional) — npm run push:vapid
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:contato@resolvajato.com.br"

# =============================================================================
# Produção Docker (resumo)
# =============================================================================
# cp .env.production.example .env
# Preencha POSTGRES_PASSWORD, EVOLUTION_API_KEY, MERCADOPAGO_* (produção)
# DOMAIN=resolvajato.com.br
# NEXT_PUBLIC_APP_URL=https://resolvajato.com.br
# npm run docker:up
# Detalhes: DOCKER.md
