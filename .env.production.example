# =============================================================================
# Produção Docker — Resolva Jato
# Copie para .env na raiz do projeto (NÃO commitar):
#   cp .env.production.example .env
# Depois: docker compose up -d --build
# Guia: DOCKER.md
# =============================================================================

# Domínio público (Caddy / Let's Encrypt)
DOMAIN=resolvajato.com.br
NEXT_PUBLIC_APP_URL=https://resolvajato.com.br

# --- PostgreSQL do app ---
POSTGRES_USER=resolvajato
POSTGRES_PASSWORD=troque-esta-senha-forte
POSTGRES_DB=resolvajato
# DATABASE_URL é montada automaticamente no compose; não precisa definir no host
# salvo se for rodar prisma localmente apontando para o container.

# --- Evolution / WhatsApp ---
EVOLUTION_API_KEY=troque-esta-chave-evolution
EVOLUTION_DB_PASSWORD=troque-senha-evolution-db
WHATSAPP_PROVIDER=evolution
WHATSAPP_API_ENABLED=true
WHATSAPP_INSTANCE=resolva-jato
# URL vista pelo host ao configurar QR (porta só em 127.0.0.1)
EVOLUTION_SERVER_URL=http://127.0.0.1:18083
# No container do app, o compose força:
#   EVOLUTION_API_URL=http://rj-evolution-api:8080

# --- Mercado Pago (credenciais de PRODUÇÃO) ---
# Painel: Suas integrações > Resolva Jato > Credenciais de produção
MERCADOPAGO_MODE=production
NEXT_PUBLIC_MERCADOPAGO_MODE=production
MERCADOPAGO_ACCESS_TOKEN=
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_CLIENT_ID=
MERCADOPAGO_CLIENT_SECRET=
MERCADOPAGO_WEBHOOK_SECRET=
# Webhook no painel MP: https://resolvajato.com.br/api/webhooks/mercadopago

# --- E-mail (SMTP Aerosuite/Gmail preferencial; Resend opcional) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=contato@aerosuite.com.br
SMTP_PASSWORD=
# From deve coincidir com SMTP_USER (evita aparência de spoofing/phishing)
SMTP_FROM=Resolva Jato <contato@aerosuite.com.br>
SMTP_REPLY_TO=contato@aerosuite.com.br
SMTP_SSL=false
SMTP_START_TLS=REQUIRED
RESEND_API_KEY=
# Ideal: domínio verificado no Resend (noreply@resolvajato.com.br)
RESEND_FROM=

# --- Auth antifraude ---
# openssl rand -hex 32
AUTH_SECRET=
# Cloudflare Turnstile: https://dash.cloudflare.com/?to=/:account/turnstile
# Domínios: resolvajato.com.br + www
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# --- SMS (Twilio) — opcional ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- Web Push (opcional) — gere com: npm run push:vapid ---
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contato@resolvajato.com.br
